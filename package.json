{
  "name": "@elementos-development/alchemy-ui",
  "version": "0.1.63",
  "description": "Alchemy UI Component Library - Design system based on Material UI v7",
  "author": "Elementos Development",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.0.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js",
      "require": "./dist/theme/index.cjs"
    },
    "./forms": {
      "types": "./dist/forms/index.d.ts",
      "import": "./dist/forms/index.js",
      "require": "./dist/forms/index.cjs"
    },
    "./charts": {
      "types": "./dist/charts/index.d.ts",
      "import": "./dist/charts/index.js",
      "require": "./dist/charts/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js",
      "require": "./dist/hooks/index.cjs"
    },
    "./email": {
      "types": "./dist/email/index.d.ts",
      "import": "./dist/email/index.js",
      "require": "./dist/email/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "src/assets",
    "src/organisms/Sidebar/assets"
  ],
  "sideEffects": false,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "tsup",
    "dev": "tsup --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint src --max-warnings=0",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "size": "size-limit",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "prepare": "husky"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "150 kB"
    },
    {
      "path": "dist/index.cjs",
      "limit": "150 kB"
    }
  ],
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --max-warnings=0",
      "prettier --write"
    ]
  },
  "peerDependencies": {
    "@emotion/react": ">=11.0.0",
    "@emotion/styled": ">=11.0.0",
    "@hookform/resolvers": ">=3.0.0",
    "@mui/material": ">=7.0.0",
    "lucide-react": ">=0.400.0",
    "@testing-library/react": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-hook-form": ">=7.0.0",
    "recharts": ">=2.0.0",
    "sonner": ">=1.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "@hookform/resolvers": {
      "optional": true
    },
    "@testing-library/react": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    },
    "recharts": {
      "optional": true
    },
    "sonner": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.2",
    "@commitlint/config-conventional": "20.5.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.0",
    "@eslint/js": "9.39.4",
    "@hookform/resolvers": "^5.2.2",
    "lucide-react": "^0.511.0",
    "@mui/material": "7.3.10",
    "@size-limit/preset-small-lib": "12.1.0",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-links": "10.4.6",
    "@storybook/addon-themes": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "eslint-plugin-storybook": "10.4.6",
    "husky": "9.1.7",
    "jsdom": "29.0.2",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.74.0",
    "recharts": "^3.8.1",
    "size-limit": "12.1.0",
    "sonner": "^2.0.7",
    "storybook": "10.4.6",
    "tsup": "8.4.0",
    "typescript": "5.9.3",
    "vite": "^6.4.2",
    "vitest": "4.1.5",
    "zod": "^4.3.6"
  },
  "keywords": [
    "react",
    "nextjs",
    "material-ui",
    "mui",
    "component-library",
    "design-system",
    "alchemy",
    "atomic-design",
    "ui"
  ]
}
